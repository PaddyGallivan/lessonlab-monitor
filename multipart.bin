  ).first();
  report.summary = {
    users: { total: users?.total || 0, paid: users?.paid || 0 },
    generated: { total: totalGenerated, saved: totalSaved, save_rate: totalGenerated > 0 ? (totalSaved / totalGenerated * 100).toFixed(0) + "%" : "0%" },
    ratings: { good: totalGood, bad: totalBad },
